# Starship prompt — bash uses bash-powerline, fish uses budspencer; nushell uses starship.
# The init is cached at ~/.cache/starship/init.nu (regenerate with `starship init nu | save -f ~/.cache/starship/init.nu`).
# `source` requires a parse-time-constant path AND that the file exists at parse time.
source ~/.cache/starship/init.nu
