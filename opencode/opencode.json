{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "lsp": "allow"
  },
  "provider": {
    "cursor": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Cursor Agent (local)",
      "options": {
        "baseURL": "http://127.0.0.1:32123/v1"
      },
      "models": {
        "auto": {
          "name": "Cursor Agent Auto"
        },
        "gpt-5": {
          "name": "Cursor Agent GPT-5 (alias → gpt-5.2)"
        },
        "gpt-5.2": {
          "name": "Cursor Agent GPT-5.2"
        },
        "gpt-5.1": {
          "name": "Cursor Agent GPT-5.1"
        },
        "gpt-5.1-codex": {
          "name": "Cursor Agent GPT-5.1 Codex"
        },
        "sonnet-4.5": {
          "name": "Cursor Agent Sonnet 4.5"
        },
        "sonnet-4.5-thinking": {
          "name": "Cursor Agent Sonnet 4.5 Thinking"
        },
        "claude-4.5-opus-thinking": {
          "name": "Claude 4.5 Opus Thinking"
        },
        "claude-4.5-opus": {
          "name": "Claude 4.5 Opus"
        }
      }
    },
    "llama.cpp": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "llama-swap",
      "options": {
        "baseURL": "http://turkishDelight:8080/v1"
      },
      "models": {
        "Gemma-4-26B-A4B-UD-Q6_K": {
          "name": "Gemma 4 26B-A4B Q6_K — Fast & Natural",
          "modalities": {
            "input": [
              "text"
            ],
            "output": [
              "text"
            ]
          },
          "limit": {
            "context": 131072,
            "output": 65536
          },
          "options": {
            "temperature": 0.85,
            "topP": 0.95
          }
        },
        "Qwen3.6-35B-A3B-MTP-UD-Q8": {
          "name": "Qwen3.6-35B-A3B MTP Q8 — Fast & Strong (MTP enabled)",
          "modalities": {
            "input": [
              "text"
            ],
            "output": [
              "text"
            ]
          },
          "limit": {
            "context": 131072,
            "output": 65536
          },
          "options": {
            "temperature": 0.9,
            "topP": 0.95
          }
        },
        "Qwen3-Coder-Next-UD-Q8": {
          "name": "Qwen3-Coder-Next-UD-Q8_K_XL",
          "modalities": {
            "input": [
              "text"
            ],
            "output": [
              "text"
            ]
          },
          "limit": {
            "context": 131072,
            "output": 65536
          }
        },
        "GLM-4.5-Air-Q6_K": {
          "name": "GLM-4.5 Air 106B MoE (12B active) - quality coding/reasoning",
          "modalities": {
            "input": [
              "text"
            ],
            "output": [
              "text"
            ]
          },
          "limit": {
            "context": 131072,
            "output": 65536
          }
        },
        "GLM-4.7-Flash-THEROCK": {
          "name": "GLM-4.7 Flash 30B MoE - coding/reasoning/agentic",
          "modalities": {
            "input": [
              "text"
            ],
            "output": [
              "text"
            ]
          },
          "limit": {
            "context": 131072,
            "output": 65536
          }
        },
        "Qwen3.5-35B-A3B-Claude-4.6-Opus-Reasoning-Distilled-Q8_0": {
          "name": "Qwen3.5 35B MoE (3B active) - Claude 4.6 Opus reasoning distill",
          "modalities": {
            "input": [
              "text"
            ],
            "output": [
              "text"
            ]
          },
          "limit": {
            "context": 131072,
            "output": 65536
          },
          "options": {
            "reasoningEffort": "high"
          }
        },
        "RNJ-1-Instruct": {
          "name": "RNJ-1 Instruct 8B - fast coding/tool calling/Ralph Wiggum loop",
          "modalities": {
            "input": [
              "text"
            ],
            "output": [
              "text"
            ]
          },
          "limit": {
            "context": 262144,
            "output": 65536
          }
        },
        "Gemma4-Coding-Q8_0": {
          "name": "Gemma 4 Coding Q8_0 - specialized code generation & software engineering",
          "modalities": {
            "input": [
              "text"
            ],
            "output": [
              "text"
            ]
          },
          "limit": {
            "context": 131072,
            "output": 65536
          }
        },
        "Qwable-27B-Q4_K_M": {
          "name": "Qwable 27B Q4_K_M - strong mid-size reasoning & general tasks",
          "modalities": {
            "input": [
              "text"
            ],
            "output": [
              "text"
            ]
          },
          "limit": {
            "context": 131072,
            "output": 65536
          }
        },
        "Gemma-4-12B-IT-BF16": {
          "name": "Gemma 4 12B IT BF16 - high-quality dense 12B model",
          "modalities": {
            "input": [
              "text"
            ],
            "output": [
              "text"
            ]
          },
          "limit": {
            "context": 131072,
            "output": 65536
          }
        },
        "Nex-AGI-N2-Pro-IQ1_M": {
          "name": "Nex-AGI N2 Pro IQ1_M - massive model (91GB) for maximum capability",
          "modalities": {
            "input": [
              "text"
            ],
            "output": [
              "text"
            ]
          },
          "limit": {
            "context": 65536,
            "output": 32768
          }
        }
      }
    }
  },
  "mcp": {
    "serena": {
      "type": "local",
      "command": [
        "serena",
        "start-mcp-server",
        "--project-from-cwd"
      ],
      "enabled": true
    },
    "kubernetes": {
      "type": "local",
      "command": [
        "kubernetes-mcp-server"
      ],
      "enabled": true
    },
    "postgres": {
      "type": "local",
      "command": [
        "postgres-mcp",
        "--access-mode=restricted"
      ],
      "environment": {
        "DATABASE_URI": "postgresql://user:pass@localhost:5432/dbname"
      },
      "enabled": false
    },
    "context7": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@upstash/context7-mcp@latest"
      ],
      "enabled": true
    }
  },
  "plugin": [
    "@zenobius/opencode-background",
    "cc-safety-net",
    "opencode-cursor-auth@1.0.16",
    "opencode-rts-sounds"
  ],
  "instructions": [
    "~/.config/opencode/plugin/shell-strategy/shell_strategy.md"
  ]
}
